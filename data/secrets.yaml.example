# Phase G secrets template (Phase G T13 + T14b)
# Copy this file: cp data/secrets.yaml.example data/secrets.yaml
# Then fill in real values. data/secrets.yaml is gitignored.

telegram:
  # Get bot_token from @BotFather Telegram chat:
  # 1. Open Telegram, search @BotFather
  # 2. /newbot → follow prompts → copy token (format "1234567890:ABCdef...")
  bot_token: "REPLACE_WITH_TOKEN"

  # Channel chat_id (broadcast — title-only post lands here):
  # 1. Tạo Telegram channel + add bot as admin với "Post Messages" permission
  # 2. Send 1 test message in channel
  # 3. Open: https://api.telegram.org/bot<TOKEN>/getUpdates
  # 4. Find "chat":{"id": <NUMBER>} — supergroup format prefix -100 (e.g. -1003957163888)
  chat_id: "REPLACE_WITH_CHANNEL_ID"

  # Linked discussion group chat_id (full body lands as thread reply here):
  # T14b — enables thread reply pattern (channel title → auto-forward → bot reply with body in thread)
  # 1. Channel Settings → Discussion → create or link group
  # 2. Add bot as ADMIN trong linked group (privacy mode auto-disabled cho admins → bot detect auto-forward)
  # 3. Get group chat_id same way (supergroup -100 prefix)
  # 4. OPTIONAL — nếu không set, fallback to legacy single-message (title + URL trong channel only)
  linked_group_chat_id: "REPLACE_WITH_GROUP_ID"

  # Article URL prefix. Update to public URL when you deploy web/.
  # Localhost works for personal testing — Telegram link only opens for you.
  base_url: "http://localhost:5174"

  # Phase H2 — separate Telegram group for inline comment feedback (Cloudflare Worker → bot → group).
  # Create a NEW private group, add bot as admin, get chat_id same way (-100 prefix).
  # If empty/REPLACE, the comment Worker will skip pushing to Telegram (worker still ack 200 to UI).
  feedback_group_chat_id: "REPLACE_WITH_FEEDBACK_GROUP_ID"

# Phase H1 — GitHub PAT for polling Pages deploy workflow.
# Required so pipeline knows when /article/<slug> is live before pushing Telegram link.
# Personal Access Token with `repo` scope (classic) OR
# Fine-grained PAT with `Actions: Read` permission on this repo.
# Verify before use:
#   curl -H "Authorization: Bearer $TOKEN" \
#     "https://api.github.com/repos/dangtrungdev113999/finpath-newsroom/actions/runs?per_page=1"
# Expect 200 + JSON. 401/403 → token wrong scope, regenerate.
github:
  token: "REPLACE_WITH_GH_PAT"
  owner: "dangtrungdev113999"
  repo: "finpath-newsroom"

# Phase Gemini Writer (Step 4.3) — google-genai SDK calls gemini-2.5-pro
# 1. Get API key: https://aistudio.google.com/apikey
# 2. Free tier: 50 requests/day. Paid tier: ~$0.005/article (input ~2k tokens + output ~500 tokens)
# 3. If empty/REPLACE → Step 4.3 will set gemini_status='skipped_disabled' (pipeline continues without Gemini side)
gemini:
  api_key: "REPLACE_WITH_GEMINI_API_KEY"

# Phase Grok Writer (Step 4.4) — openai SDK with xAI base_url
# 1. Get API key: https://console.x.ai/team (xAI Console → API Keys). Real keys start with `xai-`
# 2. Model: grok-4.3 by default (~16s/article, cleaner output — no meta leak, correct
#    proper nouns). Available alternatives that the writer was tested against:
#      - grok-4-fast-non-reasoning   (~10s, but leaks [Opening]/[Closing] bracket
#                                     labels and hallucinated proper nouns in early tests)
#      - grok-4-1-fast-non-reasoning (Grok 4.1 fast — untested for writing)
#      - grok-4.20-0309-non-reasoning, grok-3, grok-3-mini, ...
#    Run `client.models.list()` to see the full set granted by your key.
#    Reasoning variants (`*-reasoning`, `grok-4-0709`) work but take 1-3 min/call —
#    overkill for prose generation from pre-fetched data_trail.
# 3. If empty/REPLACE → Step 4.4 will set grok_status='skipped_disabled' (pipeline continues without Grok side)
grok:
  api_key: "REPLACE_WITH_GROK_API_KEY"
  model: "grok-4.3"
